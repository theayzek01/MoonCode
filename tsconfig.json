{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@moodcli/core": ["./packages/core/src/index.ts"],
			"@moodcli/core/oauth": ["./packages/core/src/oauth.ts"],
			"@moodcli/core/*": ["./packages/core/src/*.ts", "./packages/core/src/providers/*.ts"],
			"@moodcli/core/dist/*": ["./packages/core/src/*"],
			"@moodcli/engine": ["./packages/engine/src/index.ts"],
			"@moodcli/engine/*": ["./packages/engine/src/*"],
			"@moodcli/cli": ["./packages/cli/src/index.ts"],
			"@moodcli/cli/hooks": ["./packages/cli/src/core/hooks/index.ts"],
			"@moodcli/cli/*": ["./packages/cli/src/*"],
			"typebox": ["./node_modules/typebox"],
			"@moodcli/tui": ["./packages/tui/src/index.ts"],
			"@moodcli/tui/*": ["./packages/tui/src/*"],
			"@moodcli/web-ui": ["./packages/web-ui/src/index.ts"],
			"@moodcli/web-ui/*": ["./packages/web-ui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*", "packages/cli/examples/**/*"],
	"exclude": ["packages/web-ui/**/*", "**/dist/**"]
}
