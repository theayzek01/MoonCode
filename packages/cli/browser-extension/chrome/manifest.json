{
  "manifest_version": 3,
  "name": "Mooncli Browser Bridge",
  "version": "0.1.1",
  "description": "Connects Chrome tabs to the local Mooncli terminal session.",
  "permissions": ["tabs", "scripting", "debugger", "activeTab", "storage", "alarms"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Mooncli Browser Bridge"
  }
}
