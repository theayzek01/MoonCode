{
  "manifest_version": 3,
  "name": "Moon Browser Bridge",
  "version": "12.5.2026.2",
  "version_name": "12.05.2026-v2",
  "description": "Connects Chrome tabs to the local Moon terminal session.",
  "permissions": [
    "tabs",
    "scripting",
    "debugger",
    "activeTab",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "cursors/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "Moon Browser Bridge"
  }
}