{
  "manifest_version": 3,
  "name": "MoonCode",
  "version": "2026.38.0",
  "version_name": "2026-v38",
  "description": "Connects Chrome tabs to MoonCode — browser automation, canvas drawing, block coding, and design workflows.",
  "permissions": ["tabs", "scripting", "debugger", "activeTab", "storage", "alarms", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "web_accessible_resources": [{ "resources": ["icons/*", "icons/**/*"], "matches": ["<all_urls>"] }],
  "background": { "service_worker": "background.js" },
  "icons": { "48": "icon.png", "128": "icon.png" },
  "action": { "default_icon": "icon.png", "default_title": "MoonCode", "default_popup": "popup.html" },
  "short_name": "MoonCode"
}
