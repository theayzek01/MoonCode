{
  "manifest_version": 3,
  "name": "MoonCode",
  "version": "2026.24.0",
  "version_name": "2026-v24",
  "description": "Connects Chrome tabs to MoonCode.",
  "permissions": [
    "tabs",
    "scripting",
    "debugger",
    "activeTab",
    "storage",
    "alarms",
    "contextMenus"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "cursors/*"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icon.png",
    "32": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "action": {
    "default_icon": "icon.png",
    "default_title": "MoonCode",
    "default_popup": "popup.html"
  },
  "short_name": "MoonCode"
}