{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"hodeus-core": ["./packages/core/src/index.ts"],
			"hodeus-core/oauth": ["./packages/core/src/oauth.ts"],
			"hodeus-core/*": ["./packages/core/src/*.ts", "./packages/core/src/providers/*.ts"],
			"hodeus-core/dist/*": ["./packages/core/src/*"],
			"hodeus-engine": ["./packages/engine/src/index.ts"],
			"hodeus-engine/*": ["./packages/engine/src/*"],
			"hodeus": ["./packages/cli/src/index.ts"],
			"hodeus/hooks": ["./packages/cli/src/core/hooks/index.ts"],
			"hodeus/*": ["./packages/cli/src/*"],
			"typebox": ["./node_modules/typebox"],
			"hodeus-tui": ["./packages/tui/src/index.ts"],
			"hodeus-tui/*": ["./packages/tui/src/*"]
		}
	},
	"include": ["packages/*/src/**/*"],
	"exclude": ["**/dist/**", "**/*.test.ts", "**/test/**", "packages/cli/examples/**/*"]
}
